{
  "description": "Research plugin hooks for citation verification and quality assurance",
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "research-synthesizer|research-evaluator",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/verify-citations.py",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
